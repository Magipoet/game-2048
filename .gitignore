# Linux related
linux/

# macOS related
macos/

# iOS related
ios/

# Android Signing (敏感信息，绝不提交)
*.jks
*.keystore
key.properties
android-signing/

# Base64 encoded keystore (敏感信息，绝不提交)
*base64*.txt

# Exceptions to above rules.
!/packages/flutter_tools/test/data/dart_dependencies_test/**/.packages
